# server/Makefile
# Builds the PLATFORMZ test server on Linux (GitHub Actions ubuntu-latest).
# Boost is pre-installed on the runner so no apt-get needed for it.
# For local mac builds: brew install boost, then uncomment the BOOST_* lines.

CXX      := g++
CXXFLAGS := -std=c++17 -O2 -Wall \
            -I/usr/include/boost   # linux default; already on the include path

# Uncomment for local mac build:
# CXXFLAGS += -I/opt/homebrew/include
# LDFLAGS  += -L/opt/homebrew/lib

LDFLAGS  := -lboost_system -lpthread

TARGET   := gameserver
SRC      := server_main.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(SRC) -o $(TARGET) $(LDFLAGS)

clean:
	rm -f $(TARGET)

.PHONY: all clean
